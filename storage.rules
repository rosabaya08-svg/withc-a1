rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isA1Master() {
      return request.auth != null
        && request.auth.token.email == "rosabaya08@gmail.com";
    }

    function userIsActive(uid) {
      return request.auth != null
        && request.auth.uid == uid
        && (
          !firestore.exists(/databases/(default)/documents/users/$(uid)) ||
          firestore.get(/databases/(default)/documents/users/$(uid)).data.account_status != "suspended"
        );
    }

    match /ad_videos/{fileName=**} {
      allow read: if true;
      allow create: if isA1Master()
        && request.resource.size < 500 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
      allow update, delete: if isA1Master();
    }

    match /app_releases/a3/{fileName=**} {
      allow read: if true;
      allow create, update: if isA1Master()
        && request.resource.size < 2 * 1024 * 1024 * 1024
        && request.resource.contentType == "application/vnd.android.package-archive";
      allow delete: if isA1Master();
    }

    match /user_uploads/{uid}/{fileName=**} {
      allow read: if true;
      allow create, update: if userIsActive(uid)
        && request.resource.size < 250 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('video/.*'));
      allow delete: if isA1Master() || userIsActive(uid);
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if isA1Master();
    }
  }
}
