{
  "rules": {
    ".read": false,
    ".write": false,
    "device_presence": {
      ".read": "auth != null && auth.token.email == 'rosabaya08@gmail.com'",
      "$deviceId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['deviceId', 'connected', 'lastHeartbeatAtMs', 'source'])"
      }
    },
    "businesses": {
      "$bizNum": {
        "device_presence": {
          ".read": "auth != null && auth.token.email == 'rosabaya08@gmail.com'",
          "$deviceId": {
            ".write": "auth != null && newData.child('bizNum').val() == $bizNum"
          }
        },
        "signals": {
          ".read": "auth != null",
          ".write": "auth != null && auth.token.email == 'rosabaya08@gmail.com'"
        }
      }
    }
  }
}
