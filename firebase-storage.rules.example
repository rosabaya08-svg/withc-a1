rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isA1Master() {
      return request.auth != null
        && request.auth.token.email == "rosabaya08@gmail.com";
    }

    match /ad_videos/{fileName=**} {
      allow read: if request.auth != null;

      allow create: if isA1Master()
        && request.resource.size < 500 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');

      allow update, delete: if isA1Master();
    }

    match /app_releases/{fileName=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if isA1Master();
    }
  }
}
